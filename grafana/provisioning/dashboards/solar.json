{
  "uid": "solar-monitor",
  "title": "Solar Monitor",
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Current Production",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"solar_production\" and r._field == \"watts_now\")\n  |> last()"
        }
      ]
    },
    {
      "id": 2,
      "title": "Current Consumption",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 500, "color": "yellow" },
              { "value": 2000, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"solar_consumption\" and r.type == \"total\" and r._field == \"watts_now\")\n  |> last()"
        }
      ]
    },
    {
      "id": 3,
      "title": "Grid Power (+ export / - import)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"solar_consumption\" and r.type == \"net\" and r._field == \"watts_now\")\n  |> last()\n  |> map(fn: (r) => ({ r with _value: r._value * -1.0 }))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Energy Today",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 5000, "color": "yellow" },
              { "value": 20000, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"solar_production\" and r._field == \"wh_today\")\n  |> last()"
        }
      ]
    },
    {
      "id": 5,
      "title": "Power",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Consumption" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Production" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Grid (export+/import-)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar_production\" and r._field == \"watts_now\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"Production\" }))",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar_consumption\" and r.type == \"total\" and r._field == \"watts_now\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"Consumption\" }))",
          "refId": "B"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"solar_consumption\" and r.type == \"net\" and r._field == \"watts_now\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _value: r._value * -1.0, _field: \"Grid (export+/import-)\" }))",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Energy Last 7 Days",
      "type": "stat",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"solar_production\" and r._field == \"wh_last_7_days\")\n  |> last()"
        }
      ]
    },
    {
      "id": 7,
      "title": "Lifetime Energy Produced",
      "type": "stat",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watth",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "green" }]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"solar_production\" and r._field == \"wh_lifetime\")\n  |> last()"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active Inverters",
      "type": "stat",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-solar" },
          "query": "from(bucket: \"solar_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"solar_production\" and r._field == \"active_inverters\")\n  |> last()"
        }
      ]
    }
  ]
}
