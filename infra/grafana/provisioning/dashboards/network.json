        }
      ]
    },
    {
      "id": 10,
      "title": "Speed Test History",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "decimals": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 6,
            "showPoints": "always"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Download" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Upload" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_speedtest\" and r._field == \"download_mbps\")\n  |> drop(columns: [\"server\"])\n  |> map(fn: (r) => ({ r with _field: \"Download\" }))",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_speedtest\" and r._field == \"upload_mbps\")\n  |> drop(columns: [\"server\"])\n  |> map(fn: (r) => ({ r with _field: \"Upload\" }))",
          "refId": "B"
        }
      ]
    }
  ]
}
