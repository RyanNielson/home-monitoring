{
  "uid": "network-monitor",
  "title": "Network Monitor",
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Ping Latency (8.8.8.8)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"network_ping\" and r.host == \"8.8.8.8\" and r._field == \"latency_ms\")\n  |> last()"
        }
      ]
    },
    {
      "id": 2,
      "title": "Ping Latency (1.1.1.1)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"network_ping\" and r.host == \"1.1.1.1\" and r._field == \"latency_ms\")\n  |> last()"
        }
      ]
    },
    {
      "id": 3,
      "title": "DNS Resolution",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"network_dns\" and r._field == \"resolve_ms\")\n  |> last()"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Response",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 200, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"network_http\" and r._field == \"response_ms\")\n  |> last()"
        }
      ]
    },
    {
      "id": 5,
      "title": "Ping Latency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_ping\" and r._field == \"latency_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.host }))"
        }
      ]
    },
    {
      "id": 6,
      "title": "DNS & HTTP Response Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "DNS" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
          },
          {
            "matcher": { "id": "byName", "options": "HTTP" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_dns\" and r._field == \"resolve_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"DNS\" }))",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_http\" and r._field == \"response_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: \"HTTP\" }))",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Download Speed",
      "type": "stat",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 25, "color": "yellow" },
              { "value": 100, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -2h)\n  |> filter(fn: (r) => r._measurement == \"network_speedtest\" and r._field == \"download_mbps\")\n  |> drop(columns: [\"server\"])\n  |> last()"
        }
      ]
    },
    {
      "id": 8,
      "title": "Upload Speed",
      "type": "stat",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -2h)\n  |> filter(fn: (r) => r._measurement == \"network_speedtest\" and r._field == \"upload_mbps\")\n  |> drop(columns: [\"server\"])\n  |> last()"
        }
      ]
    },
    {
      "id": 9,
      "title": "Speedtest Ping",
      "type": "stat",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
