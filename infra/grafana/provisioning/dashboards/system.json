{
  "uid": "system-monitor",
  "title": "System Monitor",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 100,
      "title": "Overview",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 60, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"cpu\" and r.cpu == \"cpu-total\" and r._field == \"usage_idle\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: 100.0 - r._value}))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "stat",
      "gridPos": { "x": 5, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"mem\" and r._field == \"used_percent\")\n  |> last()"
        }
      ]
    },
    {
      "id": 3,
      "title": "Disk Usage (/)",
      "type": "stat",
      "gridPos": { "x": 10, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"disk\" and r.path == \"/\" and r._field == \"used_percent\")\n  |> last()"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 15, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "text" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"system\" and r._field == \"uptime\")\n  |> last()"
        }
      ]
    },
    {
      "id": 5,
      "title": "Battery",
      "type": "stat",
      "gridPos": { "x": 19, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 20, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          },
          "noValue": "No Battery"
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"macos_power\" and r._field == \"battery_percent\")\n  |> last()"
        }
      ]
    },
    {
      "id": 101,
      "title": "CPU",
      "type": "row",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 30,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "usage_user" },
            "properties": [{ "id": "displayName", "value": "User" }]
          },
          {
            "matcher": { "id": "byName", "options": "usage_system" },
            "properties": [{ "id": "displayName", "value": "System" }]
          },
          {
            "matcher": { "id": "byName", "options": "usage_idle" },
            "properties": [{ "id": "displayName", "value": "Idle" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cpu\" and r.cpu == \"cpu-total\")\n  |> filter(fn: (r) => r._field == \"usage_user\" or r._field == \"usage_system\" or r._field == \"usage_idle\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 7,
      "title": "System Load",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "load1" },
            "properties": [{ "id": "displayName", "value": "1 min" }]
          },
          {
            "matcher": { "id": "byName", "options": "load5" },
            "properties": [{ "id": "displayName", "value": "5 min" }]
          },
          {
            "matcher": { "id": "byName", "options": "load15" },
            "properties": [{ "id": "displayName", "value": "15 min" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"system\")\n  |> filter(fn: (r) => r._field == \"load1\" or r._field == \"load5\" or r._field == \"load15\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 102,
      "title": "Memory",
      "type": "row",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 30,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [
              { "id": "displayName", "value": "Used" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cached" },
            "properties": [
              { "id": "displayName", "value": "Cached" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "available" },
            "properties": [
              { "id": "displayName", "value": "Available" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mem\")\n  |> filter(fn: (r) => r._field == \"used\" or r._field == \"cached\" or r._field == \"available\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 9,
      "title": "Swap Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [{ "id": "displayName", "value": "Used" }]
          },
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [{ "id": "displayName", "value": "Total" }]
          },
          {
            "matcher": { "id": "byName", "options": "free" },
            "properties": [{ "id": "displayName", "value": "Free" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"swap\")\n  |> filter(fn: (r) => r._field == \"used\" or r._field == \"total\" or r._field == \"free\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 103,
      "title": "Disk",
      "type": "row",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "read_bytes" },
            "properties": [{ "id": "displayName", "value": "Read" }]
          },
          {
            "matcher": { "id": "byName", "options": "write_bytes" },
            "properties": [{ "id": "displayName", "value": "Write" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"diskio\" and r.name == \"disk0\")\n  |> filter(fn: (r) => r._field == \"read_bytes\" or r._field == \"write_bytes\")\n  |> derivative(unit: 1s, nonNegative: true)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 11,
      "title": "Disk Space",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "usedRec = from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"disk\" and r.path == \"/\" and r._field == \"used\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\ntotalRec = from(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"disk\" and r.path == \"/\" and r._field == \"total\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\nusedGB = string(v: int(v: float(v: usedRec._value) / 1000000000.0))\ntotalGB = string(v: int(v: float(v: totalRec._value) / 1000000000.0))\n\nfrom(bucket: \"home_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"disk\" and r.path == \"/\" and r._field == \"used_percent\")\n  |> last()\n  |> map(fn: (r) => ({r with _field: usedGB + \" GB / \" + totalGB + \" GB\"}))\n  |> keep(columns: [\"_field\", \"_value\"])"
        }
      ]
    },
    {
      "id": 104,
      "title": "Network",
      "type": "row",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 12,
      "title": "Network Traffic (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bytes_sent" },
            "properties": [{ "id": "displayName", "value": "Sent" }]
          },
          {
            "matcher": { "id": "byName", "options": "bytes_recv" },
            "properties": [{ "id": "displayName", "value": "Received" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"net\" and r.interface == \"en0\")\n  |> filter(fn: (r) => r._field == \"bytes_sent\" or r._field == \"bytes_recv\")\n  |> derivative(unit: 1s, nonNegative: true)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 105,
      "title": "Battery",
      "type": "row",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "Battery Level Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 42, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 20, "color": "yellow" },
              { "value": 50, "color": "green" }
            ]
          },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "noValue": "No Battery"
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"macos_power\" and r._field == \"battery_percent\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "id": 14,
      "title": "Power State",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 42, "w": 12, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "lineInterpolation": "stepAfter"
          },
          "noValue": "No Battery"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ac_power" },
            "properties": [{ "id": "displayName", "value": "AC Power" }]
          },
          {
            "matcher": { "id": "byName", "options": "charging" },
            "properties": [{ "id": "displayName", "value": "Charging" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"home_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"macos_power\")\n  |> filter(fn: (r) => r._field == \"ac_power\" or r._field == \"charging\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)"
        }
      ]
    }
  ]
}
