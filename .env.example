# =============================================================================
# Enphase IQ Gateway
# =============================================================================

# IP address of your Enphase IQ Gateway on your local network.
# Find it by running: ping enphase.local
ENPHASE_HOST=envoy.local

# JWT token for the local API (IQ Gateway firmware 7.x+).
# Generate one at: https://entrez.enphaseenergy.com/tokens
# Select your system, set a long expiry, and paste the token here.
ENPHASE_TOKEN=

# =============================================================================
# InfluxDB
# =============================================================================

# Generate a strong token: openssl rand -hex 32
INFLUXDB_TOKEN=change-me-use-openssl-rand-hex-32

INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme123
INFLUXDB_ORG=solar
INFLUXDB_BUCKET=solar_metrics

# =============================================================================
# Grafana
# =============================================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Collector
# =============================================================================

# How often to poll the gateway in seconds (default: 60)
COLLECT_INTERVAL=60
