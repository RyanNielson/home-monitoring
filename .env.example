# =============================================================================
# InfluxDB
# =============================================================================

# Generate a strong token: openssl rand -hex 32
INFLUXDB_TOKEN=change-me-use-openssl-rand-hex-32

INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme123
INFLUXDB_ORG=home
INFLUXDB_BUCKET=home_metrics

# =============================================================================
# Grafana
# =============================================================================

GRAFANA_PORT=3030
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme123

# =============================================================================
# Solar Collector
# =============================================================================

# IP address of your Enphase IQ Gateway on your local network.
# Find it by running: ping enphase.local
SOLAR_ENPHASE_HOST=1.2.3.4

# JWT token for the local API (IQ Gateway firmware 7.x+).
# Generate one at: https://entrez.enphaseenergy.com/tokens
# Select your system, set a long expiry, and paste the token here.
SOLAR_ENPHASE_TOKEN=

# How often to poll the gateway in seconds (default: 60)
SOLAR_COLLECT_INTERVAL=60

# =============================================================================
# Weather Collector
# =============================================================================

# Your location coordinates (used by Open-Meteo API)
# Find yours at: https://open-meteo.com/en/docs
WEATHER_LATITUDE=
WEATHER_LONGITUDE=

# How often to poll weather in seconds (default: 300)
WEATHER_COLLECT_INTERVAL=300

# =============================================================================
# Network Collector
# =============================================================================

# Comma-separated ping targets (default: 8.8.8.8,1.1.1.1)
NETWORK_PING_TARGETS=8.8.8.8,1.1.1.1

# Host used for DNS resolution timing (default: google.com)
NETWORK_DNS_TEST_HOST=google.com

# URL used for HTTP response timing (default: https://www.google.com)
NETWORK_HTTP_TEST_URL=https://www.google.com

# How often to collect ping/dns/http in seconds (default: 60)
NETWORK_COLLECT_INTERVAL=60

# How often to run a speed test in seconds (default: 3600)
NETWORK_SPEEDTEST_INTERVAL=3600

# Speedtest server ID for consistent results (find with: speedtest --servers)
# Leave blank to auto-select the nearest server.
NETWORK_SPEEDTEST_SERVER=

# =============================================================================
# System Collector (Telegraf)
# =============================================================================

# How often to collect system metrics (default: 30s)
# Telegraf is auto-installed via Homebrew if not present.
SYSTEM_COLLECT_INTERVAL=30s